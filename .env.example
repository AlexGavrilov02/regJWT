# Секретный ключ для подписи JWT (минимум 32 символа, сгенерируйте уникальный)
SECRET_KEY= 
# URL подключения к базе данных
# SQLite:
DATABASE_URL=sqlite:///./auth.db
# PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/authdb

# Срок жизни access-токена (минуты)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Срок жизни refresh-токена (дни)
REFRESH_TOKEN_EXPIRE_DAYS=7

# Максимум попыток входа до блокировки
MAX_LOGIN_ATTEMPTS=5

# Время блокировки после превышения попыток (минуты)
LOCKOUT_DURATION_MINUTES=15